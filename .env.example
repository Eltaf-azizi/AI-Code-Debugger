# OpenAI API Configuration
OPENAI_API_KEY="sk-your-api-key-here"

# Model Configuration
MODEL_NAME="gpt-4"
TEMPERATURE=0.5
MAX_TOKENS=4000

# Application Settings
DEFAULT_THEME="dark"
ENABLE_HISTORY=true
ENABLE_FILE_UPLOAD=true
ENABLE_CODE_COMPARISON=true

# Advanced Settings
REQUEST_TIMEOUT=60
RETRY_ATTEMPTS=3

# UI Settings
SHOW_LINE_NUMBERS=true
ENABLE_ANIMATIONS=true
AUTO_SAVE_SESSIONS=true
