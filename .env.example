# OpenAI API Configuration
OPENAI_API_KEY="sk-your-api-key-here"
MODEL_NAME="gpt-4"
TEMPERATURE=0.5
MAX_TOKENS=4000

# Application Settings
APP_NAME="AI Code Assistant"
APP_VERSION="1.0.0"
DEBUG=false

# File Handling
MAX_FILE_SIZE=100000
CHUNK_SIZE=4000
MAX_CHUNKS=10

# Database
DATABASE_URL=""
DATABASE_ECHO=false

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# API Configuration
API_PREFIX="/api/v1"
API_TITLE="AI Code Assistant API"
API_DESCRIPTION="AI-powered code analysis, debugging, and optimization API"

# CORS (comma-separated origins)
CORS_ORIGINS="*"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security
SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
